        <!-- ============ BOOKINGS ============ -->
        <mxCell id="bookings" value="Bookings" style="swimlane;fontStyle=1;fontSize=14;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=28;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneFillColor=#FFFFFF;fillColor=#FFE6CC;strokeColor=#D79B00;" vertex="1" parent="1">
