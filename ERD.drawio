<mxfile host="app.diagrams.net" type="device">
  <diagram name="Football Ticket Booking ERD" id="football-erd">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============ USERS ============ -->
        <mxCell id="users" value="Users" style="swimlane;fontStyle=1;fontSize=14;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=28;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneFillColor=#FFFFFF;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="260" height="158" as="geometry" />
        </mxCell>
        <mxCell id="u1" value="user_id : INT   [PK]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;fontStyle=4;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="users">
          <mxGeometry y="28" width="260" height="26" as="geometry" />
        </mxCell>
        <mxCell id="u2" value="full_name : VARCHAR(100)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="users">
          <mxGeometry y="54" width="260" height="26" as="geometry" />
        </mxCell>
        <mxCell id="u3" value="email : VARCHAR(255)   [UNIQUE]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="users">
          <mxGeometry y="80" width="260" height="26" as="geometry" />
        </mxCell>
        <mxCell id="u4" value="role : VARCHAR(20)   [Fan / Manager]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="users">
          <mxGeometry y="106" width="260" height="26" as="geometry" />
        </mxCell>
        <mxCell id="u5" value="phone_number : VARCHAR(20)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="users">
          <mxGeometry y="132" width="260" height="26" as="geometry" />
        </mxCell>

        <!-- ============ MATCHES ============ -->
        <mxCell id="matches" value="Matches" style="swimlane;fontStyle=1;fontSize=14;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=28;horizontalStack=0;resizeParent=1;resizeParentMax=0;collapsible=0;marginBottom=0;swimlaneFillColor=#FFFFFF;fillColor=#D5E8D4;strokeColor=#82B366;" vertex="1" parent="1">
          <mxGeometry x="660" y="40" width="300" height="158" as="geometry" />
