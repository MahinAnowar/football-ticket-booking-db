        <!-- ============ RELATIONSHIPS (Crow's Foot) ============ -->
        <mxCell id="e1" value="One User  →  Many Bookings" style="edgeStyle=entityRelationEdgeStyle;fontSize=11;html=1;rounded=0;endArrow=ERmandOne;startArrow=ERmany;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="b2" target="u1">
