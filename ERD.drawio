        <mxCell id="b6" value="total_cost : NUMERIC(10,2)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="bookings">
