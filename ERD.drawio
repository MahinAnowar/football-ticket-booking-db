        <mxCell id="m2" value="fixture : VARCHAR(150)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="matches">
