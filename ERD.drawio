        <mxCell id="m1" value="match_id : INT   [PK]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;fontStyle=4;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="matches">
          <mxGeometry y="28" width="300" height="26" as="geometry" />
